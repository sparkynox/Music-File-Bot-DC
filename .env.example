# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Telegram bot token (from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Max file size in MB that each platform is allowed to send.
# Discord depends on server boost level: 10 (none) / 50 (level 2) / 100 (level 3)
DISCORD_MAX_MB=50

# Telegram bot API hard limit is 50MB for uploads
TELEGRAM_MAX_MB=50

# Optional: path to a YouTube cookies.txt file (Netscape format).
# Needed only if you still see "Sign in to confirm you're not a bot" errors.
# Leave blank/unset if you don't need it.
YTDLP_COOKIES_FILE=

# Show a second message after /start about this being a small free
# hosting plan, with Clone / Source Code buttons. true or false.
SHOW_HOSTING_NOTICE=true
